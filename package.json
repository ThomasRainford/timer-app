{
  "name": "timer-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:vercel": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint .",
    "db:migrate:reset": "dotenv -e .env.local -- npx prisma migrate reset",
    "db:migrate:create": "dotenv -e .env.local -- npx prisma migrate dev --name",
    "prisma:studio": "dotenv -e .env.local -- npx prisma studio",
    "prisma:generate": "dotenv -e .env.local -- npx prisma generate",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "prisma": {
    "seed": "dotenv -e .env.local -- ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv-cli": "^11.0.0",
    "next": "^16",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "react": "^19",
    "react-dom": "^19",
    "use-sound": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "daisyui": "^5.5.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.14",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
